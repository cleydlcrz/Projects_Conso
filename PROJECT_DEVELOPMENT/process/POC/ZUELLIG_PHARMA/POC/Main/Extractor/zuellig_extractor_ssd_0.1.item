  <node componentName="tJavaRow" componentVersion="0.101" offsetLabelX="0" offsetLabelY="0" posX="920" posY="120">
    <elementParameter field="TEXT" name="UNIQUE_NAME" value="tJavaRow_2" show="false"/>
    <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="//input.rawLine = &quot;     Period  --  01-Dec-2025  To  31-Dec-2025&quot;&#xD;&#xA;String line = (input_row.datedata != null) ? input_row.datedata : &quot;&quot;;&#xD;&#xA;&#xD;&#xA;java.util.regex.Pattern p = java.util.regex.Pattern.compile(&#xD;&#xA; &quot;Period\\s*--\\s*(\\d{2}-\\w{3}-\\d{4})\\s*To\\s*(\\d{2}-\\w{3}-\\d{4})&quot;&#xD;&#xA;);&#xD;&#xA;java.util.regex.Matcher m = p.matcher(line);&#xD;&#xA;&#xD;&#xA;String periodStart = null;&#xD;&#xA;String periodEnd   = null;&#xD;&#xA;&#xD;&#xA;if (m.find()) {&#xD;&#xA; periodStart = m.group(1); // &quot;01-Dec-2025&quot;&#xD;&#xA; periodEnd   = m.group(2); // &quot;31-Dec-2025&quot;&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;//Save so Subjob 2 can use it later&#xD;&#xA;globalMap.put(&quot;PERIOD_START&quot;, periodStart);&#xD;&#xA;globalMap.put(&quot;PERIOD_END&quot;, periodEnd);&#xD;&#xA;&#xD;&#xA;System.out.println(&quot;============================================&quot;);&#xD;&#xA;System.out.println(&quot;File Start Period&#x9;&#x9;&#x9;:&quot; +periodStart);&#xD;&#xA;System.out.println(&quot;File End Period&#x9;&#x9;&#x9;&#x9;:&quot; +periodEnd);&#xD;&#xA;System.out.println(&quot;============================================&quot;);&#xD;&#xA;"/>
    <elementParameter field="MEMO_EDITOR_IMPORT" name="IMPORT" value="//import java.util.List;"/>
    <elementParameter field="TEXT" name="CONNECTION_FORMAT" value="row"/>
    <metadata connector="FLOW" name="tJavaRow_2"/>
  </node>

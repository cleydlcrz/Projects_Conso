      <elementParameter field="MEMO_EDITOR_JAVA" name="CODE" value="String filter = context.email_subject_filter_1;&#xD;&#xA;&#xD;&#xA;if (filter == null || filter.trim().isEmpty()) {&#xD;&#xA;    filter = &quot;.*&quot;;&#xD;&#xA;}else{&#xD;&#xA;&#x9;filter.replace(&quot;*&quot;, &quot;.*&quot;);&#xD;&#xA;}&#xD;&#xA;&#xD;&#xA;globalMap.put(&quot;subject_filter_1&quot;, filter);"/>
